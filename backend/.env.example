# Stock Analyzer - Production Environment Configuration

# ============ Application ============
ENVIRONMENT=production
DEBUG=false

# ============ Frontend ============
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ML_API_URL=http://localhost:5001
REACT_APP_ENVIRONMENT=production

# ============ Backend ============
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:80
LOG_LEVEL=INFO
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============ ML Service ============
ML_SERVICE_PORT=5001
ML_SERVICE_TIMEOUT=30
SEQUENCE_LENGTH=60
USE_LSTM=false

# ============ External APIs ============
# Get your API key from https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ============ Redis (Optional) ============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============ MySQL Database ============
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=stock_analyzer
MYSQL_USER=stockuser
MYSQL_PASSWORD=stockpassword
MYSQL_ROOT_PASSWORD=rootpassword

# ============ phpMyAdmin (Optional) ============
PHPMYADMIN_PORT=8080

# ============ Authentication ============
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
