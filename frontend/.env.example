# Frontend Environment Variables

# Application
REACT_APP_NAME=Stock Analyzer
REACT_APP_VERSION=1.0.0
REACT_APP_ENVIRONMENT=development

# API Endpoints
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ML_API_URL=http://localhost:5001
REACT_APP_API_TIMEOUT=30000

# External APIs
REACT_APP_FINNHUB_API_KEY=your_finnhub_key_here
REACT_APP_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Feature Flags
REACT_APP_ENABLE_PREDICTION=true
REACT_APP_ENABLE_PORTFOLIO=true
REACT_APP_ENABLE_ANALYSIS=true
REACT_APP_DEBUG=false

# Cache TTL (milliseconds)
REACT_APP_QUOTE_CACHE_TTL=60000
REACT_APP_PROFILE_CACHE_TTL=3600000
REACT_APP_NEWS_CACHE_TTL=900000
